import shutil
import os
from zipfile import ZipFile

# Re-create installer structure due to environment reset
installer_dir = "/mnt/data/GAIA_Windows_Installer"
os.makedirs(installer_dir, exist_ok=True)

# Placeholder installer files
placeholder_files = [
    "GAIA_Setup.exe",
    "installer_config.json",
    "install_script.bat",
    "README_FIRST.txt",
    "LICENSE.txt"
]

# Create the placeholder files
for filename in placeholder_files:
    with open(os.path.join(installer_dir, filename), "w") as f:
        f.write(f"This is a placeholder for {filename} in the GAIA installer.")

# Create a ZIP archive of the installer directory
installer_zip_path = "/mnt/data/GAIA_Windows_Installer.zip"
shutil.make_archive(base_name=installer_zip_path.replace(".zip", ""), format='zip', root_dir=installer_dir)

installer_zip_path
